{
  "name": "peerdrop-desktop",
  "version": "1.0.0",
  "description": "Cross-platform offline P2P sharing app",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.peerdrop.desktop",
    "productName": "PeerDrop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
